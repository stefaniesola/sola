---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { MetaPageEvent } from "../../lib/meta";

const metaPageEvent: MetaPageEvent = {
  eventName: "Contact",
  dedupe: "session",
  dedupeKey: "contact:algemeen-contactformulier",
  parameters: {
    content_name: "SOLA algemeen contact",
    content_category: "Contact",
  },
};
---

<BaseLayout
  title="Bedankt voor je bericht | SOLA Travel"
  description="We hebben je bericht goed ontvangen."
  robots="noindex, nofollow"
  metaPageEvent={metaPageEvent}
>
  <section class="sola-thankyou-page">
    <div class="sola-thankyou-container">
      <h1>Bedankt, je bericht is goed ontvangen.</h1>
      <p>
        We nemen zo snel mogelijk persoonlijk contact met je op via de gegevens
        die je hebt ingevuld.
      </p>

      <h2>Intussen</h2>
      <ul>
        <li>Bekijk de veelgestelde vragen als je praktisch iets wil nakijken.</li>
        <li>Ontdek de SOLA weekends als je het aanbod rustig wil vergelijken.</li>
      </ul>

      <div class="sola-thankyou-cta" aria-label="Vervolgacties">
        <a class="btn btn-primary" href="/weekenden">Bekijk de SOLA weekends</a>
        <div class="sola-thankyou-cta-links">
          <a class="btn btn-secondary" href="/faq">Veelgestelde vragen</a>
          <a class="btn btn-secondary" href="/">Naar de startpagina</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

