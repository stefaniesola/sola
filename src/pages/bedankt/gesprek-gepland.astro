---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { MetaPageEvent } from "../../lib/meta";

const metaPageEvent: MetaPageEvent = {
  eventName: "Schedule",
  dedupe: "session",
  dedupeKey: "schedule:sola-kennismakingsgesprek",
  parameters: {
    content_name: "SOLA kennismakingsgesprek",
    content_category: "Intermittent Living",
  },
};
---

<BaseLayout
  title="Gesprek gepland | SOLA Travel"
  description="Je kennismakingsgesprek met SOLA is ingepland."
  robots="noindex, nofollow"
  metaPageEvent={metaPageEvent}
>
  <section class="sola-thankyou-page">
    <div class="sola-thankyou-container">
      <h1>Je gesprek is ingepland.</h1>
      <p>
        Bedankt om tijd vrij te maken. Je ontvangt de bevestiging en praktische
        gegevens via e-mail.
      </p>

      <h2>Voor je gesprek</h2>
      <ul>
        <li>Bekijk gerust nog even de weekendpagina.</li>
        <li>Noteer je belangrijkste vragen vooraf.</li>
        <li>Annuleer of verplaats via Calendly als het moment niet past.</li>
      </ul>

      <div class="sola-thankyou-cta" aria-label="Vervolgacties">
        <a class="btn btn-primary" href="/weekenden/intermittent-living">
          Bekijk Intermittent Living
        </a>
        <div class="sola-thankyou-cta-links">
          <a class="btn btn-secondary" href="/contact">Contact</a>
          <a class="btn btn-secondary" href="/">Naar de startpagina</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

