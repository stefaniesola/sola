---
import WeekendTemplate from "./[slug].astro";
import type { Journey } from "../../data/content";
import { journeys } from "../../data/content";

const sourceWeekend = journeys.find(
  (journey) => journey.slug === "intermittent-living",
);

if (!sourceWeekend) {
  throw new Error("Intermittent Living weekend data not found.");
}

const heroImage = sourceWeekend.heroImage;
const heroImageData =
  heroImage && typeof heroImage !== "string"
    ? {
        src: heroImage.src,
        width: heroImage.width,
        height: heroImage.height,
        format: heroImage.format,
      }
    : sourceWeekend.heroImageData;

const weekend: Journey = {
  ...sourceWeekend,
  heroImage: typeof heroImage === "string" ? heroImage : heroImage?.src,
  heroImageData,
};
---

<WeekendTemplate weekend={weekend} />
