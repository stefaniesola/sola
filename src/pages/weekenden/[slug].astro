---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ImageMetadata } from "astro";
import type { Journey } from "../../data/content";
import { journeys } from "../../data/content";
import { getImage } from "astro:assets";
import bewustwordingImage from "../../assets/images/2631991747.jpg";
import { processMarkdown, slugifyHeading } from "../../utils/markdown";
import carouselImageOne from "../../assets/images/2596052607.jpg";
import carouselImageTwo from "../../assets/images/2631991747.jpg";
import carouselImageThree from "../../assets/images/hero.jpg";
import carouselImageFour from "../../assets/images/landscape.jpg";
import carouselImageFive from "../../assets/images/famenne.jpg";
import carouselImageSix from "../../assets/images/haute-loire.jpg";
import carouselImageSeven from "../../assets/images/1513986998.jpg";
import simonExpertPortrait from "../../assets/images/simon-helleputte.webp";
import sarahExpertPortrait from "../../assets/images/Sarah Deleu therapeut - groen.jpg";
import johanExpertPortrait from "../../assets/images/johanportret.jpg";
import intermittentLivingWeekendImage from "../../assets/images/Intermittent Living - Hoge Venen - op weekend (7).jpeg";

export async function getStaticPaths() {
  const weekends = journeys.filter((journey) => journey.type === "Weekend");
  return Promise.all(
    weekends.map(async (weekend) => {
      let imageUrl =
        typeof weekend.heroImage === "string"
          ? weekend.heroImage
          : weekend.heroImage?.src;
      let heroImageData;
      if (weekend.heroImage) {
        if (typeof weekend.heroImage === "string") {
          if (weekend.heroImage.startsWith("/src/assets/images/")) {
            if (weekend.slug === "bewustwording-connectie") {
              heroImageData = await getImage({
                src: bewustwordingImage,
                width: 1600,
                quality: 85,
              });
              imageUrl = heroImageData.src;
            }
          }
        } else {
          heroImageData = await getImage({
            src: weekend.heroImage,
            width: 1600,
            quality: 85,
          });
          imageUrl = heroImageData.src;
        }
      }
      return {
        params: { slug: weekend.slug },
        props: {
          weekend: { ...weekend, heroImage: imageUrl, heroImageData },
        },
      };
    }),
  );
}

const { weekend } = Astro.props as { weekend: Journey };

type MarkdownSection = {
  title: string;
  id: string;
  content: string;
  html: string;
  toc: { id: string; text: string; level: number }[];
};

type TocEntry = {
  id: string;
  text: string;
  level: number;
};

type MarkdownSubsection = {
  title: string;
  id: string;
  content: string;
  html: string;
};

const markdownContent = weekend.longread || "";
const keyFacts = weekend.keyFacts ?? [];
const faqItems = weekend.faq ?? [];
const metaDescriptionBase = `${weekend.shortDescription} Locatie: ${weekend.location}. Data: ${weekend.dates}.`;
const metaDescription =
  metaDescriptionBase.length > 160
    ? `${metaDescriptionBase.slice(0, 157).trimEnd()}...`
    : metaDescriptionBase;
const weekendTitle = `SOLA Travel | ${weekend.name} | ${weekend.location}`;
const heroImageAlt = `${weekend.name} in ${weekend.location}`;
const linkClass = "text-accent-700 hover:text-accent-800";
const linkedMoreInfoCopy =
  "Ontdek hoe SOLA weekenden opbouwt, leer het team kennen of plan een gesprek voor je inschrijving.".replace(
    "inschrijving",
    `<a href="/terms" class="${linkClass}">inschrijving</a>`,
  );
const baseUrl = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const absoluteHeroImage = weekend.heroImage
  ? new URL(weekend.heroImage, baseUrl).toString()
  : undefined;
const priceValue = weekend.price.match(/\d+([.,]\d+)?/g)?.join("");
const touristTripSchema = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: weekend.name,
  description: weekend.shortDescription,
  image: absoluteHeroImage,
  url: canonicalUrl,
  provider: {
    "@type": "Organization",
    name: "SOLA",
    url: baseUrl.toString(),
  },
  location: {
    "@type": "Place",
    name: weekend.location,
  },
  ...(priceValue
    ? {
        offers: {
          "@type": "Offer",
          price: priceValue,
          priceCurrency: "EUR",
          url: canonicalUrl,
        },
      }
    : {}),
};
const faqSchema = faqItems.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }
  : null;
const structuredData = [touristTripSchema, faqSchema].filter(Boolean);
const ctaLinks =
  weekend.slug === "exercise-is-medicine" ||
  weekend.slug === "bewustwording-connectie" ||
  weekend.slug === "intermittent-living"
    ? {
        bookUrl: "https://tally.so/r/pbogoy",
        consultUrl:
          "https://calendly.com/hello-solatravel/30min?month=2026-02",
        target: "_blank",
        rel: "noopener noreferrer",
      }
    : {
        bookUrl: "#boek-je-plek",
        consultUrl: "#twijfel-je",
        target: undefined,
        rel: undefined,
      };

const normalizeTitle = (value: string) =>
  value
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^\w\s-]/g, "")
    .trim();

const buildSections = (markdown: string) => {
  const lines = markdown.split("\n");
  const introLines: string[] = [];
  const sections: { title: string; content: string }[] = [];
  let currentTitle = "";
  let currentContent: string[] = [];

  lines.forEach((line) => {
    const match = line.match(/^##\s+(.+)$/);
    if (match) {
      if (currentTitle) {
        sections.push({
          title: currentTitle,
          content: currentContent.join("\n").trim(),
        });
      } else if (introLines.length > 0) {
        introLines.push("");
      }
      currentTitle = match[1].trim();
      currentContent = [];
      return;
    }
    if (currentTitle) {
      currentContent.push(line);
    } else {
      introLines.push(line);
    }
  });

  if (currentTitle) {
    sections.push({
      title: currentTitle,
      content: currentContent.join("\n").trim(),
    });
  }

  return { introMarkdown: introLines.join("\n").trim(), sections };
};

const buildMarkdownSection = (
  section: { title: string; content: string },
  index: number,
): MarkdownSection => {
  const id = slugifyHeading(section.title) || `section-${index + 1}`;
  const processed = processMarkdown(section.content);
  return {
    ...section,
    id,
    html: processed.html,
    toc: processed.toc.filter((item) => item.level > 2),
  };
};

const splitSubsections = (markdown: string): MarkdownSubsection[] => {
  const lines = markdown.split("\n");
  const subsections: { title: string; content: string }[] = [];
  let currentTitle = "";
  let currentContent: string[] = [];

  lines.forEach((line) => {
    const match = line.match(/^###\s+(.+)$/);
    if (match) {
      if (currentTitle) {
        subsections.push({
          title: currentTitle,
          content: currentContent.join("\n").trim(),
        });
      }
      currentTitle = match[1].trim();
      currentContent = [];
      return;
    }
    if (currentTitle) {
      currentContent.push(line);
    }
  });

  if (currentTitle) {
    subsections.push({
      title: currentTitle,
      content: currentContent.join("\n").trim(),
    });
  }

  return subsections.map((section, index) => ({
    ...section,
    id: slugifyHeading(section.title) || `subsection-${index + 1}`,
    html: processMarkdown(section.content).html,
  }));
};

const parseDetailCards = (markdown: string) =>
  markdown
    .split("\n")
    .map((line) => line.trim())
    .map((line) => line.replace(/\s{2,}$/g, ""))
    .map((line) => line.match(/^\*\*(.+?):\*\*\s*(.+)$/))
    .filter((match): match is RegExpMatchArray => Boolean(match))
    .map((match) => ({
      label: match[1].trim(),
      lines: [match[2].trim()],
    }));

const sectionMatches = (
  section: MarkdownSection | undefined,
  predicates: string[],
) => {
  if (!section) return false;
  const normalized = normalizeTitle(section.title);
  return predicates.some((predicate) => normalized.includes(predicate));
};

const { introMarkdown, sections } = buildSections(markdownContent);
const introHtml = introMarkdown ? processMarkdown(introMarkdown).html : "";
const contentSections = sections.map(buildMarkdownSection);
const findSection = (predicates: string[]) =>
  contentSections.find((section) => sectionMatches(section, predicates));
const isFaqSection = (section: MarkdownSection) =>
  sectionMatches(section, ["faq", "goed om weten"]);
const isClosingSection = (section: MarkdownSection) =>
  sectionMatches(section, ["boek je plek", "twijfel je", "na inschrijving"]);
const audienceSection = findSection(["voor wie"]);
const focusSection = findSection([
  "wat je leert",
  "wat leer je",
  "wat mag je verwachten",
  "focus",
]);
const afterSection = findSection(["na dit weekend"]);
const expertSection = findSection([
  "expertise",
  "coordinatie",
  "begeleiding",
  "experts",
]);
const programSection = findSection(["programma"]);
const staySection = findSection(["verblijf"]);
const mealsSection = findSection(["maaltijden"]);
const practicalSection = findSection(["praktisch"]);
const giftSection = findSection(["vroegboek"]);
const includedSection = findSection(["wat is inbegrepen"]);
const excludedSection = findSection(["wat is niet inbegrepen"]);
const bookingSection = findSection(["boek je plek"]);
const doubtSection = findSection(["twijfel je"]);
const afterSignupSection = findSection(["na inschrijving"]);

const categorizedIds = new Set(
  [
    audienceSection,
    focusSection,
    afterSection,
    expertSection,
    programSection,
    staySection,
    mealsSection,
    practicalSection,
    giftSection,
    includedSection,
    excludedSection,
    bookingSection,
    doubtSection,
    afterSignupSection,
  ]
    .filter(Boolean)
    .map((section) => section!.id),
);
const otherVisibleSections = contentSections.filter(
  (section) =>
    !categorizedIds.has(section.id) &&
    !isFaqSection(section) &&
    !isClosingSection(section),
);
const practicalSubsections = practicalSection
  ? splitSubsections(practicalSection.content)
  : [];
const practicalStayOrMeals = practicalSubsections.filter((section) => {
  const normalized = normalizeTitle(section.title);
  return normalized.includes("verblijf") || normalized.includes("maaltijden");
});
const stayMealsBlocks = [
  ...(staySection
    ? [
        {
          title: staySection.title,
          id: staySection.id,
          html: staySection.html,
        },
      ]
    : []),
  ...(mealsSection
    ? [
        {
          title: mealsSection.title,
          id: mealsSection.id,
          html: mealsSection.html,
        },
      ]
    : []),
  ...(staySection || mealsSection
    ? []
    : practicalStayOrMeals.map((section) => ({
        title: section.title,
        id: section.id,
        html: section.html,
      }))),
];
const practicalCards =
  practicalSection && parseDetailCards(practicalSection.content).length > 0
    ? parseDetailCards(practicalSection.content)
    : keyFacts;
const showPracticalProse =
  practicalSection &&
  parseDetailCards(practicalSection.content).length === 0 &&
  practicalStayOrMeals.length === 0;
const faqSection = contentSections.find(isFaqSection);
const endCtaSections = [bookingSection, doubtSection, afterSignupSection].filter(
  Boolean,
) as MarkdownSection[];
const whyContentBySlug: Record<
  string,
  { eyebrow: string; title: string; body: string; signals: string[] }
> = {
  "exercise-is-medicine": {
    eyebrow: "Waarom dit weekend?",
    title: "Begrijp hoe beweging je hart, energie en herstel sterker maakt.",
    body: "Dit weekend maakt concreet wat gerichte inspanning doet met je cardiovasculaire gezondheid, metabolisme en mentale veerkracht. Je koppelt metingen aan lichaamsgevoel en vertaalt die inzichten naar slimmer trainen, beter herstellen en haalbare gewoontes voor je dagelijks leven. Zo wordt beweging geen extra druk op je agenda, maar een onderbouwde manier om meer energie, belastbaarheid en vertrouwen in je lichaam op te bouwen.",
    signals: [
      "Inspanningsfysiologie vertaald naar je eigen lichaam",
      "Meten, voelen en bijsturen in plaats van zomaar harder trainen",
      "Beweging in de Hoge Venen als krachtige leeromgeving",
    ],
  },
  "bewustwording-connectie": {
    eyebrow: "Waarom dit weekend?",
    title: "Meer grip op wat je voelt, doet en herhaalt onder druk.",
    body: "Dit weekend helpt je begrijpen hoe stress, patronen en lichamelijke signalen elkaar beïnvloeden. Je krijgt een helder kader en oefent met technieken die spanning reguleren, bewust reageren ondersteunen en thuis bruikbaar blijven. Niet als zweverige omweg, wel als praktische verdieping in hoe je systeem werkt en hoe je daar met meer keuzevrijheid mee omgaat.",
    signals: [
      "Psychologie en stressregulatie helder uitgelegd",
      "EFT, systemisch werk en beweging concreet geoefend",
      "Rust, veiligheid en integratie in een kleine groep",
    ],
  },
  "intermittent-living": {
    eyebrow: "Waarom dit weekend?",
    title: "Versterk je energie en herstel.",
    body: "Dit weekend draait rond performance, herstel en leren schakelen tussen actie en rust. Via beweging, ademhaling, voeding, bioritme en gerichte prikkels ontdek je hoe je lichaam stress verwerkt en hoe je energie, focus en herstel bewuster kan sturen.",
    signals: [
      "KPNI en leefstijlprincipes vertaald naar performance",
      "Beweging, ademhaling, voeding en bioritme in praktijk",
      "Concrete tools voor energie, herstel en focus",
    ],
  },
};
const whyContent =
  whyContentBySlug[weekend.slug] ?? {
    eyebrow: "Waarom dit weekend?",
    title: "Een compacte investering in beter begrijpen wat je gezondheid draagt.",
    body: weekend.shortDescription,
    signals: [
      "Onderbouwde inzichten",
      "Ervaringsgericht leren",
      "Kleine groep in de natuur",
    ],
  };

const heroTagsBySlug: Record<string, string[]> = {
  "exercise-is-medicine": ["Cardio", "Metabolisme", "Herstel", "Performance"],
  "bewustwording-connectie": ["Regulatie", "Inzicht", "Connectie", "Veerkracht"],
  "intermittent-living": ["Energie", "Herstel", "Ademhaling", "Beweging", "Voeding"],
};
const heroTags =
  heroTagsBySlug[weekend.slug] ?? ["Gezondheid", "Natuur", "Inzicht"];
const heroFactLabels = ["wanneer", "data", "datum", "waar", "locatie", "prijs"];
const matchedHeroFacts = keyFacts
  .filter((fact) =>
    heroFactLabels.some((label) => normalizeTitle(fact.label).includes(label)),
  )
  .slice(0, 3);
const heroFacts = matchedHeroFacts.length > 0 ? matchedHeroFacts : keyFacts.slice(0, 3);
const atmosphereVideoBySlug: Record<
  string,
  { src: string; type: string; label: string }
> = {
  "exercise-is-medicine": {
    src: "/simon-uitleg-website.mp4",
    type: "video/mp4",
    label:
      "Simon Helleputte legt uit wat je tijdens het weekend Beweging als medicijn leert",
  },
};
const atmosphereVideo = atmosphereVideoBySlug[weekend.slug];

const uniqueNavItems = (items: TocEntry[]) => {
  const seen = new Set<string>();
  return items.filter((item) => {
    if (!item.id || seen.has(item.id)) return false;
    seen.add(item.id);
    return true;
  });
};

const primaryNavItems: TocEntry[] = uniqueNavItems(
  [
    { id: "waarom-dit-weekend", text: "Waarom", level: 2 },
    audienceSection && { id: audienceSection.id, text: "Voor wie", level: 2 },
    focusSection && { id: focusSection.id, text: "Wat je leert", level: 2 },
    afterSection && { id: afterSection.id, text: "Na afloop", level: 2 },
    expertSection && { id: expertSection.id, text: "Expertise", level: 2 },
    programSection && { id: programSection.id, text: "Programma", level: 2 },
    (practicalSection || staySection || mealsSection) && {
      id: practicalSection?.id ?? staySection?.id ?? mealsSection?.id ?? "praktisch",
      text: "Praktisch",
      level: 2,
    },
    faqItems.length && { id: "faq", text: "FAQ", level: 2 },
    { id: "boek-je-plek", text: "Boeken", level: 2 },
  ].filter(Boolean) as TocEntry[],
);
const mobileNavItems: TocEntry[] = uniqueNavItems(
  [
    { id: "waarom-dit-weekend", text: "Waarom", level: 2 },
    focusSection && { id: focusSection.id, text: "Wat je leert", level: 2 },
    programSection && { id: programSection.id, text: "Programma", level: 2 },
    (practicalSection || staySection || mealsSection) && {
      id: practicalSection?.id ?? staySection?.id ?? mealsSection?.id ?? "praktisch",
      text: "Praktisch",
      level: 2,
    },
    { id: "boek-je-plek", text: "Boeken", level: 2 },
  ].filter(Boolean) as TocEntry[],
);

const carouselSources = weekend.galleryImages ?? [
  carouselImageOne,
  carouselImageTwo,
  carouselImageThree,
  carouselImageFour,
  carouselImageFive,
  carouselImageSix,
  carouselImageSeven,
];
const carouselAlts = weekend.galleryAlts ?? [];
const galleryImages = await Promise.all(
  carouselSources.map(async (image) =>
    getImage({
      src: image,
      width: 1100,
      quality: 84,
    }),
  ),
);
const altForImage = (index: number) =>
  carouselAlts[index] ?? `${weekend.name} sfeerbeeld ${index + 1}`;
const mediaOrderBySlug: Record<string, number[]> = {
  "exercise-is-medicine": [2, 3, 0, 4, 5, 1],
  "bewustwording-connectie": [2, 7, 6, 0, 1, 4],
  "intermittent-living": [0, 1, 2, 3, 4, 7],
};
const orderedGalleryItems = (
  mediaOrderBySlug[weekend.slug] ?? galleryImages.map((_, index) => index)
)
  .map((index) =>
    galleryImages[index]
      ? { image: galleryImages[index], alt: altForImage(index), index }
      : null,
  )
  .filter(Boolean) as { image: Awaited<ReturnType<typeof getImage>>; alt: string; index: number }[];
const atmosphereItems = orderedGalleryItems.slice(0, 6);
const supplementalAtmosphereSources: Record<
  string,
  { src: ImageMetadata; alt: string }[]
> = {
  "exercise-is-medicine": [
    {
      src: intermittentLivingWeekendImage,
      alt: "Deelnemers tijdens een weekendmoment in de Hoge Venen",
    },
  ],
};
const supplementalAtmosphereItems = await Promise.all(
  (supplementalAtmosphereSources[weekend.slug] ?? []).map(async (item) => ({
    image: await getImage({
      src: item.src,
      width: 900,
      quality: 84,
    }),
    alt: item.alt,
  })),
);
const videoSideItems = atmosphereVideo
  ? [
      ...atmosphereItems.slice(1, 5),
      ...(weekend.slug === "exercise-is-medicine" && atmosphereItems[0]
        ? [atmosphereItems[0]]
        : []),
      ...supplementalAtmosphereItems,
    ].slice(0, 6)
  : [];
const expertImageIndexBySlug: Record<string, number> = {
  "exercise-is-medicine": 3,
  "bewustwording-connectie": 6,
  "intermittent-living": 12,
};
const expertImageIndex =
  expertImageIndexBySlug[weekend.slug] ?? galleryImages.length - 1;
const expertImage =
  galleryImages[expertImageIndex] ?? orderedGalleryItems[0]?.image;
const expertImageAlt =
  galleryImages[expertImageIndex]
    ? altForImage(expertImageIndex)
    : (orderedGalleryItems[0]?.alt ?? heroImageAlt);
const expertPortraitSources: Record<string, ImageMetadata> = {
  "exercise-is-medicine": simonExpertPortrait,
  "bewustwording-connectie": sarahExpertPortrait,
  "intermittent-living": johanExpertPortrait,
};
const expertPortraitAlts: Record<string, string> = {
  "exercise-is-medicine": "Simon Helleputte van Simon Endurance Lab",
  "bewustwording-connectie": "Sarah Deleu van Logisch Gezond",
  "intermittent-living": "Johan De Coninck van Antwerp Rehab & Training",
};
const expertPortraitSource = expertPortraitSources[weekend.slug];
const expertPortrait = expertPortraitSource
  ? await getImage({
      src: expertPortraitSource,
      width: 900,
      quality: 86,
    })
  : undefined;
const expertMedia = expertPortrait ?? expertImage;
const expertMediaAlt = expertPortrait
  ? expertPortraitAlts[weekend.slug]
  : expertImageAlt;
---

<BaseLayout
  title={weekendTitle}
  description={metaDescription}
  ogImage={weekend.heroImage}
  ogImageAlt={heroImageAlt}
  structuredData={structuredData}
>
  <section class="relative isolate overflow-hidden bg-base-900 text-white">
    {weekend.heroImage && (
      <img
        class="absolute inset-0 h-full w-full object-cover brightness-105 contrast-105 saturate-110"
        src={weekend.heroImage}
        width={weekend.heroImageData?.width ?? 1600}
        height={weekend.heroImageData?.height ?? 1067}
        alt={heroImageAlt}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-base-950/54 via-base-900/22 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-base-950/16 via-transparent to-white/5"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-base-25 to-transparent"></div>

    <div
      class="relative mx-auto grid min-h-[78svh] max-w-6xl items-end gap-10 px-5 pb-12 pt-28 sm:px-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:pb-16 lg:pt-36"
      data-weekend-media-hero
    >
      <div class="max-w-3xl space-y-6">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/75">
          {weekend.type} rond gezondheid, natuur en inzicht
        </p>
        <div class="space-y-4">
          <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
            {weekend.name}
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed text-white/90">
            {weekend.shortDescription}
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          {heroTags.map((tag) => (
            <span class="border border-white/35 bg-white/15 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-white backdrop-blur-sm">
              {tag}
            </span>
          ))}
        </div>
        <div class="flex flex-col gap-3 pt-1 sm:flex-row">
          <a
            href={ctaLinks.bookUrl}
            target={ctaLinks.target}
            rel={ctaLinks.rel}
            class="inline-flex items-center justify-center rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
          >
            Boek nu
          </a>
          <a
            href={ctaLinks.consultUrl}
            target={ctaLinks.target}
            rel={ctaLinks.rel}
            class="inline-flex items-center justify-center rounded-full border border-white/60 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
          >
            Plan een gesprek
          </a>
        </div>
