---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Bedankt | SOLA Travel";
const description =
  "Bedankt — we hebben je bericht of inschrijving goed ontvangen. Bekijk de volgende stap voor SOLA weekends, contact of nieuwsbrief.";

const type = Astro.url.searchParams.get("type");
const typeLineMap: Record<string, string> = {
  nieuwsbrief: "Je staat nu op de SOLA nieuwsbrief.",
  contact: "We hebben je bericht ontvangen.",
  tally: "We hebben je inschrijving goed ontvangen.",
};
const typeLine = type ? typeLineMap[type] ?? null : null;
---

<BaseLayout title={title} description={description}>
  <section class="sola-thankyou-page">
    <div class="sola-thankyou-container">
      <h1>Bedankt — we hebben alles goed ontvangen.</h1>
      <p>
        Je aanvraag of inschrijving is <strong>succesvol doorgestuurd</strong>.
        We sturen je snel een bevestiging of nemen contact met je op.
      </p>

      {typeLine && <p class="sola-thankyou-type-line">{typeLine}</p>}

      <h2>Volgende stap</h2>
      <ul>
        <li>Bekijk het aanbod en het programma.</li>
        <li>Heb je een vraag? Stuur me gerust een bericht.</li>
        <li>Wil je rustig meevolgen? Hou je inbox in de gaten.</li>
      </ul>

      <div class="sola-thankyou-cta" aria-label="Vervolgacties">
        <a class="btn btn-primary" href="/weekenden">Bekijk de SOLA weekends</a>

        <div class="sola-thankyou-cta-links">
          <a class="btn btn-secondary" href="/faq">Veelgestelde vragen</a>
          <a class="btn btn-secondary" href="/">Naar de startpagina</a>
        </div>

        <div class="sola-thankyou-whatsapp">
          <a
            href="https://wa.me/32493410738"
            target="_blank"
            rel="noopener noreferrer"
          >
            Stuur een WhatsApp-bericht
          </a>
          <small>+32 493 41 07 38</small>
        </div>
      </div>

      <p class="sola-thankyou-fineprint">
        Tip: voeg solatravel.be toe aan je contacten zodat je onze e-mails zeker
        ontvangt.
      </p>
    </div>
  </section>
</BaseLayout>
