---
import "../styles/global.css";
import MetaPixel from "./analytics/MetaPixel.astro";
import type { MetaPageEvent } from "../lib/meta";
import { DEFAULT_DESCRIPTION, DEFAULT_TITLE, SITE_NAME } from "../utils/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  robots?: string;
  metaPageEvent?: MetaPageEvent;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage,
  ogImageAlt = "SOLA Travel",
  ogType = "website",
  robots = "index, follow",
  metaPageEvent,
  structuredData,
} = Astro.props as Props;

const baseUrl = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, baseUrl);
const absoluteOgImage = ogImage
  ? new URL(ogImage, baseUrl).toString()
  : undefined;

const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const serializeStructuredData = (item: Record<string, unknown>) =>
  JSON.stringify(item).replace(/</g, "\\u003c");
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE_NAME} />
<meta name="robots" content={robots} />
<meta name="theme-color" content="#f6f4f0" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="shortcut icon" href="/apple-touch-icon.png" type="image/png" />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="nl_BE" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.toString()} />
{absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta property="og:image:alt" content={ogImageAlt} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta name="twitter:image:alt" content={ogImageAlt} />}
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="canonical" href={canonicalURL.toString()} />
<link rel="sitemap" href="/sitemap-index.xml" />
{structuredDataItems.map((item) => (
  <script type="application/ld+json" set:html={serializeStructuredData(item)} />
))}
<MetaPixel pageEvent={metaPageEvent} />
<script is:inline>
  (() => {
    const preparedVideos = new WeakSet();

    const prepareSolaVideo = (node) => {
      const video =
        node instanceof HTMLVideoElement
          ? node
          : node instanceof HTMLElement
            ? node.closest("video")
            : null;

      if (!video || preparedVideos.has(video)) return;

      const isSimonVideo = Array.from(video.querySelectorAll("source")).some(
        (source) =>
          source.getAttribute("src")?.includes("simon-uitleg-website.mp4"),
      );

      if (!isSimonVideo) return;

      preparedVideos.add(video);
      video.removeAttribute("autoplay");
      video.defaultMuted = true;
      video.muted = true;
      video.playsInline = true;
      video.preload = "none";

      let userInteracted = false;
      const markUserInteracted = () => {
        userInteracted = true;
      };

      video.addEventListener("pointerdown", markUserInteracted, {
        passive: true,
      });
      video.addEventListener("keydown", markUserInteracted);

      const startVideo = () => {
        if (video.dataset.solaAutoplayStarted === "true") return;

        video.dataset.solaAutoplayStarted = "true";
        video.preload = "metadata";
        const playAttempt = video.play();

        if (playAttempt && typeof playAttempt.catch === "function") {
          playAttempt.catch(() => {
            video.dataset.solaAutoplayStarted = "false";
          });
        }
      };

      if ("IntersectionObserver" in window) {
        const lazyAutoplayObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                startVideo();
                return;
              }

              if (!userInteracted && !video.paused && entry.intersectionRatio < 0.05) {
                video.pause();
              }
            });
          },
          {
            rootMargin: "320px 0px",
            threshold: [0.05, 0.35],
          },
        );

        lazyAutoplayObserver.observe(video);
      } else {
        window.addEventListener(
          "load",
          () => window.setTimeout(startVideo, 1200),
          { once: true },
        );
      }
    };

    const scanVideoNode = (node) => {
      prepareSolaVideo(node);
      if (node instanceof HTMLElement) {
        node.querySelectorAll("video").forEach(prepareSolaVideo);
      }
    };

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach(scanVideoNode);
      });
    });

    observer.observe(document.documentElement, {
      childList: true,
      subtree: true,
    });

    document.addEventListener(
      "DOMContentLoaded",
      () => {
        document.querySelectorAll("video").forEach(prepareSolaVideo);
        observer.disconnect();
      },
      { once: true },
    );
  })();
</script>
{import.meta.env.PROD && (
  <script>
    import { initSolaGoogleTracking } from "../scripts/google-tracking";

    initSolaGoogleTracking();
  </script>
)}
