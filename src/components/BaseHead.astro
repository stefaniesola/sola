---
import "../styles/global.css";
import { DEFAULT_DESCRIPTION, DEFAULT_TITLE, SITE_NAME } from "../utils/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage,
  ogImageAlt = "SOLA Travel",
  ogType = "website",
  structuredData,
} = Astro.props as Props;

const baseUrl = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, baseUrl);
const absoluteOgImage = ogImage
  ? new URL(ogImage, baseUrl).toString()
  : undefined;

const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const serializeStructuredData = (item: Record<string, unknown>) =>
  JSON.stringify(item).replace(/</g, "\\u003c");
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE_NAME} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#f6f4f0" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="shortcut icon" href="/apple-touch-icon.png" type="image/png" />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="nl_BE" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.toString()} />
{absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta property="og:image:alt" content={ogImageAlt} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta name="twitter:image:alt" content={ogImageAlt} />}
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="canonical" href={canonicalURL.toString()} />
<link rel="sitemap" href="/sitemap-index.xml" />
{structuredDataItems.map((item) => (
  <script type="application/ld+json" set:html={serializeStructuredData(item)} />
))}
{import.meta.env.PROD && (
  <>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = window.gtag || gtag;

      const loadSolaTracking = () => {
        if (window.__solaTrackingLoaded) return;
        window.__solaTrackingLoaded = true;

        const gtagScript = document.createElement('script');
        gtagScript.async = true;
        gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-QKFM5L5T7R';
        document.head.appendChild(gtagScript);
        gtag('js', new Date());
        gtag('config', 'G-QKFM5L5T7R');

        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WXRV8S6Z');

        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '2265839607276716');
        fbq('track', 'PageView');
      };

      const scheduleSolaTracking = () => {
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadSolaTracking, { timeout: 2500 });
          return;
        }
        window.setTimeout(loadSolaTracking, 1200);
      };

      if (document.readyState === 'complete') {
        scheduleSolaTracking();
      } else {
        window.addEventListener('load', scheduleSolaTracking, { once: true });
      }
    </script>
    <noscript>
    <img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=2265839607276716&ev=PageView&noscript=1"
    />
    </noscript>
  </>
)}
