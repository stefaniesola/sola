<div
  data-sola-consent-banner
  hidden
  class="fixed inset-x-0 bottom-0 z-[80] border-t border-base-200 bg-base-25/95 px-5 py-5 shadow-[0_-16px_40px_rgba(62,52,42,0.14)] backdrop-blur-md"
>
  <div class="mx-auto grid max-w-6xl gap-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
    <div class="space-y-3">
      <p class="text-sm font-semibold text-base-900">Cookievoorkeuren</p>
      <p class="max-w-3xl text-sm leading-relaxed text-base-700">
        SOLA gebruikt noodzakelijke cookies voor de website. Analytics en
        marketingcookies, zoals de Meta Pixel, laden alleen wanneer je daarvoor
        toestemming geeft.
      </p>
      <div data-sola-consent-preferences-panel hidden class="grid gap-3 sm:grid-cols-2">
        <label class="flex items-start gap-3 border border-base-200 bg-white p-3 text-sm text-base-700">
          <input
            data-sola-consent-analytics
            type="checkbox"
            class="mt-1 h-4 w-4 rounded border-base-300 text-accent-600 focus:ring-accent-500"
          />
          <span>
            <span class="block font-semibold text-base-900">Analytics</span>
            <span class="block">Helpt ons begrijpen welke pagina's werken.</span>
          </span>
        </label>
        <label class="flex items-start gap-3 border border-base-200 bg-white p-3 text-sm text-base-700">
          <input
            data-sola-consent-marketing
            type="checkbox"
            class="mt-1 h-4 w-4 rounded border-base-300 text-accent-600 focus:ring-accent-500"
          />
          <span>
            <span class="block font-semibold text-base-900">Marketing</span>
            <span class="block">Laat Meta-events toe voor campagneoptimalisatie.</span>
          </span>
        </label>
      </div>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row lg:justify-end">
      <button
        type="button"
        data-sola-consent-necessary
        class="inline-flex items-center justify-center rounded-full border border-base-300 px-4 py-2 text-sm font-semibold text-base-800 transition-colors hover:border-base-500"
      >
        Alleen noodzakelijk
      </button>
      <button
        type="button"
        data-sola-consent-toggle
        class="inline-flex items-center justify-center rounded-full border border-base-300 px-4 py-2 text-sm font-semibold text-base-800 transition-colors hover:border-accent-500 hover:text-accent-700"
      >
        Voorkeuren
      </button>
      <button
        type="button"
        data-sola-consent-save
        hidden
        class="inline-flex items-center justify-center rounded-full bg-base-900 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-base-800"
      >
        Keuze opslaan
      </button>
      <button
        type="button"
        data-sola-consent-all
        class="inline-flex items-center justify-center rounded-full bg-accent-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-700"
      >
        Alles accepteren
      </button>
    </div>
  </div>
</div>

<script>
  import { getConsent, readStoredConsent, saveConsent } from "../../scripts/consent";

  const banner = document.querySelector<HTMLElement>("[data-sola-consent-banner]");
  const preferencesPanel = document.querySelector<HTMLElement>(
    "[data-sola-consent-preferences-panel]",
  );
  const analyticsInput = document.querySelector<HTMLInputElement>(
    "[data-sola-consent-analytics]",
  );
  const marketingInput = document.querySelector<HTMLInputElement>(
    "[data-sola-consent-marketing]",
  );
  const saveButton = document.querySelector<HTMLButtonElement>(
    "[data-sola-consent-save]",
  );
  const toggleButton = document.querySelector<HTMLButtonElement>(
    "[data-sola-consent-toggle]",
  );

  const syncInputs = () => {
    const state = getConsent();
    if (analyticsInput) analyticsInput.checked = state.analytics;
    if (marketingInput) marketingInput.checked = state.marketing;
  };

  const showBanner = () => {
    syncInputs();
    banner?.removeAttribute("hidden");
  };

  const hideBanner = () => {
    banner?.setAttribute("hidden", "");
    preferencesPanel?.setAttribute("hidden", "");
    saveButton?.setAttribute("hidden", "");
  };

  document
    .querySelector("[data-sola-consent-necessary]")
    ?.addEventListener("click", () => {
      saveConsent({ analytics: false, marketing: false });
      hideBanner();
    });

  document
    .querySelector("[data-sola-consent-all]")
    ?.addEventListener("click", () => {
      saveConsent({ analytics: true, marketing: true });
      hideBanner();
    });

  toggleButton?.addEventListener("click", () => {
    syncInputs();
    preferencesPanel?.removeAttribute("hidden");
    saveButton?.removeAttribute("hidden");
  });

  saveButton?.addEventListener("click", () => {
    saveConsent({
      analytics: analyticsInput?.checked === true,
      marketing: marketingInput?.checked === true,
    });
    hideBanner();
  });

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target : null;
    if (!target?.closest("[data-sola-open-consent]")) return;
    event.preventDefault();
    showBanner();
  });

  if (!readStoredConsent()) {
    showBanner();
  } else {
    syncInputs();
  }
</script>

