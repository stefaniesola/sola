<style is:global>
  .journey-page a[href^="https://calendly.com/hello-solatravel/30min"] {
    border-color: transparent !important;
    background-color: var(--color-accent-500, #c9784d) !important;
    color: #fff !important;
  }

  .journey-page a[href^="https://calendly.com/hello-solatravel/30min"]:hover {
    background-color: var(--color-accent-600, #b7653d) !important;
    color: #fff !important;
  }
</style>

<script is:inline>
  (() => {
    const cleanWeekendConsultLinks = () => {
      document
        .querySelectorAll('a[href^="https://calendly.com/hello-solatravel/30min"]')
        .forEach((link) => {
          const cleanUrl = new URL("https://calendly.com/hello-solatravel/30min");
          try {
            const currentUrl = new URL(link.href);
            currentUrl.searchParams.forEach((value, key) => {
              if (key.startsWith("utm_")) {
                cleanUrl.searchParams.set(key, value);
              }
            });
          } catch {
            // Keep the clean Calendly URL if the current href is malformed.
          }
          link.setAttribute("href", cleanUrl.toString());
          if (link.textContent && link.textContent.trim() === "Plan gesprek") {
            link.textContent = "Plan een gesprek";
          }
        });
    };

    cleanWeekendConsultLinks();
    document.addEventListener("DOMContentLoaded", cleanWeekendConsultLinks, {
      once: true,
    });
  })();
</script>
