{
  "redirects": [
    {
      "source": "/(.*)/",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "solatravel.be"
        }
      ],
      "destination": "https://www.solatravel.be/$1",
      "permanent": true
    }
  ]
}
